{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks\"/dangerous-command-blocker.sh",
            "statusMessage": "Checking for dangerous commands..."
          },
          {
            "type": "command",
            "command": "\".claude/hooks\"/db-guard.sh",
            "statusMessage": "Checking for unsafe database operations..."
          },
          {
            "type": "command",
            "command": "\".claude/hooks\"/secret-protection-input.sh",
            "statusMessage": "Checking for sensitive file access..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks\"/file-protection.sh",
            "statusMessage": "Protecting sensitive files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks\"/secret-protection-output.sh",
            "statusMessage": "Scanning for leaked secrets..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks\"/pre-compact-state-save.sh",
            "statusMessage": "Saving pre-compaction state...",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/geniro-check-update.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\".claude/hooks\"/post-compact-notification.sh",
            "statusMessage": "Notifying of compaction...",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
